# Diagnostic-only Gemma 4 verification profile.
# This is not a baseline-valid profile and must not replace the default Gemma 3 setup.
LOCAL_AI_BACKEND=http
LOCAL_AI_HTTP_BASE_URL=http://inference:11434
LOCAL_AI_HTTP_MODEL=gemma4:e2b
LOCAL_AI_HTTP_PROFILE=conservative
WORKER_CONCURRENCY=3
WORKER_POOL=prefork
OLLAMA_NUM_PARALLEL=1
LOCAL_AI_HTTP_TIMEOUT_SECONDS=300
LOCAL_AI_HTTP_TIMEOUT_SEGMENT_SECONDS=300
LOCAL_AI_HTTP_TIMEOUT_SUMMARY_SECONDS=180
LOCAL_AI_HTTP_TIMEOUT_TOPICS_SECONDS=180
LOCAL_AI_HTTP_MAX_RETRIES=0
INFERENCE_MEM_LIMIT=10G
