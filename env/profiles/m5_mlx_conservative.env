# Preferred opt-in M5 Pro profile for host MLX-LM inference.
# Start mlx_lm.server on the Mac host before starting Docker services.
LOCAL_AI_BACKEND=http
LOCAL_AI_HTTP_API=openai_compat
LOCAL_AI_HTTP_BASE_URL=http://host.docker.internal:8080
HOST_MLX_BASE_URL=http://localhost:8080
LOCAL_AI_HTTP_MODEL=mlx-community/gemma-3-text-4b-it-4bit
LOCAL_AI_HTTP_PROFILE=conservative
WORKER_CONCURRENCY=2
WORKER_POOL=prefork
OLLAMA_NUM_PARALLEL=1
LOCAL_AI_HTTP_TIMEOUT_SECONDS=240
LOCAL_AI_HTTP_TIMEOUT_SEGMENT_SECONDS=240
LOCAL_AI_HTTP_TIMEOUT_SUMMARY_SECONDS=180
LOCAL_AI_HTTP_TIMEOUT_TOPICS_SECONDS=180
LOCAL_AI_HTTP_MAX_RETRIES=0
LLM_CONTEXT_WINDOW=8192
LLM_SUMMARY_MAX_TEXT=12000
LLM_SUMMARY_MAX_TOKENS=512
