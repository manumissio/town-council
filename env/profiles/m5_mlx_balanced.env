# Higher-throughput opt-in M5 Pro profile for host MLX-LM inference.
# Use after the conservative profile is stable on representative workloads.
LOCAL_AI_BACKEND=http
LOCAL_AI_HTTP_API=openai_compat
LOCAL_AI_HTTP_BASE_URL=http://host.docker.internal:8080
HOST_MLX_BASE_URL=http://localhost:8080
LOCAL_AI_HTTP_MODEL=mlx-community/gemma-4-e2b-it-OptiQ-4bit
LOCAL_AI_HTTP_PROFILE=balanced
WORKER_CONCURRENCY=4
WORKER_POOL=prefork
OLLAMA_NUM_PARALLEL=1
LOCAL_AI_HTTP_TIMEOUT_SECONDS=180
LOCAL_AI_HTTP_TIMEOUT_SEGMENT_SECONDS=180
LOCAL_AI_HTTP_TIMEOUT_SUMMARY_SECONDS=120
LOCAL_AI_HTTP_TIMEOUT_TOPICS_SECONDS=120
LOCAL_AI_HTTP_MAX_RETRIES=1
LLM_CONTEXT_WINDOW=8192
LLM_SUMMARY_MAX_TEXT=12000
LLM_SUMMARY_MAX_TOKENS=512

